rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: books
    // Document ID: auto-generated string
    // Fields:
    //   - title: string (required, 1-200 chars)
    //   - author: string (required, 1-100 chars)
    //   - description: string (required, 1-5000 chars)
    //   - categories: list of strings (required, max 10 items)
    //   - coverImageUrl: string (optional, valid URL)
    //   - publishedYear: number (optional, positive integer)
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: users
    // Document ID: user UID
    // Fields:
    //   - uid: string (required, immutable)
    //   - email: string (required, valid email)
    //   - displayName: string (optional)
    //   - role: string (required, 'admin' or 'viewer')
    //   - createdAt: timestamp (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "chowdaryyeshwanth07@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      return hasRequiredFields(['uid', 'email', 'role', 'createdAt']) &&
             hasOnlyAllowedFields(['uid', 'email', 'displayName', 'role', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.email == request.auth.token.email &&
             data.role in ['admin', 'viewer'] &&
             data.createdAt is timestamp;
    }

    function isValidBook(data) {
      return hasRequiredFields(['title', 'author', 'description', 'categories', 'createdAt']) &&
             hasOnlyAllowedFields(['title', 'author', 'description', 'categories', 'coverImageUrl', 'publishedYear', 'viewUrl', 'downloadUrl', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.author is string && data.author.size() > 0 && data.author.size() <= 100 &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 5000 &&
             data.categories is list && data.categories.size() <= 10 &&
             (!('coverImageUrl' in data) || (data.coverImageUrl is string && data.coverImageUrl.size() <= 1000)) &&
             (!('publishedYear' in data) || (data.publishedYear is int)) &&
             (!('viewUrl' in data) || (data.viewUrl is string && data.viewUrl.size() <= 1000)) &&
             (!('downloadUrl' in data) || (data.downloadUrl is string && data.downloadUrl.size() <= 1000)) &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Books collection
    match /books/{bookId} {
      // Anyone can read books (public library)
      allow read: if true;
      
      // Only admins can create, update, or delete books
      allow create: if isAdmin() && isValidBook(request.resource.data);
      allow update: if isAdmin() && isValidBook(request.resource.data) &&
                      request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAdmin();
    }

    // Users collection (for roles)
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'viewer' || isAdmin());
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();
    }

    // Diagnostic collection for connection testing
    match /test/connection {
      allow read: if true;
    }
  }
}
